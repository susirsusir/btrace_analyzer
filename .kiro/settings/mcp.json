{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "disabled": false,
      "autoApprove": [
        "new_page",
        "list_pages",
        "evaluate_script",
        "wait_for",
        "click",
        "take_snapshot",
        "take_screenshot",
        "close_page",
        "type_text",
        "press_key"
      ]
    }
  }
}